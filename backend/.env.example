# MolForge AI — Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Gemini (Required) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_db

# --- PubMed (Optional — increases rate limit from 3 to 10 req/s) ---
PUBMED_API_KEY=

# --- Server ---
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Logging ---
LOG_LEVEL=INFO

# --- Pipeline Tuning ---
MAX_CANDIDATES=25
NOVELTY_THRESHOLD=0.85
SA_SCORE_MAX=6.0
